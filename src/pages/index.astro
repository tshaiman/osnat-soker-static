---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';

const PHONE = '050-5289895';
const EMAIL = 'soker.osnat@gmail.com';

// Inline SVG geometric icons (polygon line-art) matching the original site palette.
function iconSvg(kind: string): string {
  const colors: Record<string, string> = {
    lime: '#BDD868',
    teal: '#00BDB4',
    magenta: '#D3348A',
  };
  const c = colors[kind] ?? '#999999';
  return `<svg width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="${c}" stroke-width="1.4" stroke-linejoin="round" aria-hidden="true">
    <path d="M32 6 52 18 52 42 32 58 12 42 12 18Z"/>
    <path d="M32 6 32 32 12 42 M32 32 52 42 M32 32 52 18 M32 32 12 18 M32 32 32 58"/>
    <circle cx="32" cy="32" r="3" fill="${c}" stroke="none"/>
  </svg>`;
}

// ---- Hero poem (Rilke) ----
const poem = [
  'חיה עכשיו',
  'את השאלות',
  'ושמא תגיע',
  'לאט לאט',
  'ביום מן הימים הרחוקים',
  'לחיות את התשובה.',
];

// ---- Why-therapy body paragraphs ----
const whyParas = [
  { text: 'פעמים רבות אדם משוכנע שהוא יכול להתמודד בכוחות עצמו עם המצוקה, לפנות לחבר קרוב ובכך לחסוך את העלויות הכרוכות בפנייה לטיפול, או לדחות את הפנייה לטיפול לזמן ״מתאים יותר״.', bold: false },
  { text: 'טיפול אינו יכול להוות תחליף לשיחה עם חבר שכן הוא מושתת על קשר עם המטפל בעבודה על ה׳לא-מודע׳ שמתוכו מתאפשר שינוי נפשי עמוק.', bold: true },
  { text: 'מרבית האנשים אינם מבינים לעומק את המנגנונים שמפעילים אותם בחיי היום יום, מדוע הם מתנהגים באופן מסויים, מדוע הם בקשרים הרסניים ומדוע הם חוזרים שוב ושוב על אותה תבנית התנהגותית. לעיתים אדם מסתובב עם ההרגשה שמשהו לא בסדר בתוכו, מרגיש תחושה של ריקנות, שמשהו חסר לו, מפתח כל מיני תסמינים גופניים שלא היו לו קודם ושאין הוא מבין את פשרם.', bold: false },
];
const whyQuote = '"האם תוכל לומר לי בבקשה באיזו דרך עלי לבחור מכאן ? ..."';
const whyQuoteSub = '"...זה תלוי רבות במקום אליו אתה רוצה להגיע, בתנאי שתלך זמן ארוך מספיק."';
const whyQuoteAttr = '(אליס בארץ הפלאות / לואיס קרול)';

// ---- About me (נעים מאוד) credential paragraphs ----
const aboutParas = [
  'שמי אסנת סוקר, בוגרת התכנית התלת שנתית בלימודים מתקדמים "מצבים מנטלים ראשוניים", התכנית לפסיכותרפיה, הפקולטה לרפואה, אוניברסיטת ת"א.',
  'בוגרת התכנית התלת שנתית בלימודים מתקדמים בנושא החשיבה הקלינית והתאורטית של ביון, מטעם המרכז ללימודי פסיכותרפיה בגישה פסיכואנליטית, גהה.',
  'בוגרת התכנית התלת שנתית ללימודי פסיכותרפיה בגישה פסיכואנליטית מטעם גהה.',
  'בוגרת תואר שני בעבודה סוציאלית במגמה הטיפולית מטעם אוניברסיטת בר אילן (עו"ס קלינית).',
  'במהלך לימודי נמניתי כמצטיינת לייצג את האוניברסיטה בכנסת.',
  'מתעסקת בעבודתי הטיפולית בהתפתחויות הרגשיות המוקדמות ובשיבושים של תחילת החיים, ואיך אלו משפיעים על האדם בבגרותו.',
  'אני בעלת ניסיון טיפולי עשיר של למעלה מ-20 שנה, במבוגרים ובבוגרים צעירים, במגוון מצוקות נפשיות כגון: דיכאון, חרדה, משברי חיים, אובדן ושכול, קשיים בזוגיות ובאינטימיות, תחושת תקיעות, פגיעות מיניות, העצמה ועוד.',
  'מטפלת לשעבר במרפאה לבריאות הנפש בחולון, וכיום בקליניקה פרטית במודיעין עם מבוגרים ובוגרים צעירים.',
];

// ---- About therapy (על הטיפול) ----
const therapyHeadQuote = '״ההחלטה לטיפול אינה מן הקלות וכרוכה בהתייסרות ובהתלבטויות קשה.״';
const therapyBlocks = [
  { text: 'פעמים רבות אדם משוכנע שהוא יכול להתמודד בכוחות עצמו עם המצוקה, לפנות לחבר קרוב ובכך לחסוך את העלויות הכרוכות בפנייה לטיפול, או לדחות את הפנייה לטיפול לזמן ״מתאים יותר״.', bold: false },
  { text: 'טיפול אינו יכול להוות תחליף לשיחה עם חבר שכן הוא מושתת על קשר עם המטפל בעבודה על ה׳לא-מודע׳ שמתוכו מתאפשר שינוי נפשי עמוק.', bold: true },
  { text: 'מרבית האנשים אינם מבינים לעומק את המנגנונים שמפעילים אותם בחיי היום יום, מדוע הם מתנהגים באופן מסויים, מדוע הם בקשרים הרסניים ומדוע הם חוזרים שוב ושוב על אותה תבנית התנהגותית. לעיתים אדם מסתובב עם ההרגשה שמשהו לא בסדר בתוכו, מרגיש תחושה של ריקנות, שמשהו חסר לו, מפתח כל מיני תסמינים גופניים שלא היו לו קודם ושאין הוא מבין את פשרם.', bold: false },
  { text: 'אני מאמינה שאוכל לעזור לאדם הפונה אלי להבין ולחשוב איתו על המשמעויות והמצוקות שהתעוררו ושמבקשות לקבל פשר, כאלו שאינן ידועות לו עדיין, על מנת שיוכל לחזור למסלול חייו ולשאת את מורכבות החיים באופן נסבל ולחיות אותם כפי שהיה רוצה עבורו.', bold: false },
  { text: 'כדי לחיות חיים אותנטיים ושלמים אדם צריך לבחור בסדרי עדיפויות נכונים', bold: true },
  { text: 'אנו חיים כיום בעידן שבו אנשים מחפשים פתרונות מהירים למצוקות שלהם, ולעיתים אינם מצליחים לגייס סובלנות, איפוק והבנה לכך שהנפש זקוקה לתהליכים משמעותיים על מנת להשתנות.', bold: false },
  { text: 'טיפול אינו בר השוואה למוצר ממשי בתרבות הצריכה של ימינו, במובן זה שהוא השקעה תהליכית שמטרתה לשפר את איכות החיים ואושרו של אדם. את תוצאותיה קשה למדוד באופן מיידי. ׳ארגז הכלים׳ שאני מעניקה במהלך המפגשים ביננו, בין אם המטופל בחר להגיע לתהליך ארוך או קצר טווח, הינו בעל ערך רב לחיים עצמם.', bold: false },
  { text: 'דחיית ההחלטה לטפל במצוקה, תוביל בטווח הארוך למצוקה מצטברת', bold: true },
  { text: 'טיפול אינו דבר קל משום שהוא מפגיש את האדם עם כאב נפשי שהוא אינו רוצה או אינו מסוגל להתמודד איתו, לכן טבעי הוא שאנשים רבים ידחו החלטה זו. פניה למטפל נתפשת עדיין כצעד המעיד על חולשה, או כשלון.', bold: false },
  { text: 'ההמנעות מלהגיע במועד לטיפול מובילה לנזק נפשי מצטבר ובסופו של דבר המצוקה הולכת וגדלה. כלפי חוץ האדם ממשיך לתפקד, לעיתים על ׳אוטומט׳, אך בתוכו נפשו כמהה ומשתוקקת למזור. מעבר להקלה בסימפטומים ובמצוקה, הטיפול עשוי לאפשר לנפש לגדול ולהתרחב כך שהיא תוכל להתמודד בסופו של דבר עם יותר מצבים מורכבים ומתסכלים שקודם לכן היא לא יכלה לשאת ולהכיל.', bold: false },
  { text: 'במהלך עבודתי התרשמתי כי לרוב מרבית האנשים טרום כניסתם לטיפול מתבוננים על מה שקורה להם בחיים מנקודת מבט אחת. הטיפול מאפשר להם לייצר תנועה נפשית בתוכם ולראות את המתרחש בחייהם מכמה נקודות מבט וזוויות שונות, דבר המוליד גמישות רבה יותר ויכולת לשאת מורכבות.', bold: false },
];
const therapyKeywords = ['פסיכותרפיה', 'יחסים בין אישיים', 'אינטימיות', 'חרדה', 'דכאון', 'אובדן', 'שכול'];

// ---- Services grid ----
const services = [
  {
    title: 'פסיכותרפיה',
    icon: 'lime',
    paras: [
      'פסיכותרפיה היא שם נרדף לטיפול נפשי, הלקוחה מהמילה היוונית פסיכו- נפש ותרפיה - טיפול. הכוונה לטיפול נפשי המתקיים באמצעות דיבור/שיחות כשהקשר האנושי בין המטפל למטופל הוא בבסיס העבודה הטיפולית.',
      'ישנם כיום לא מעט זרמים וגישות טיפוליות וכל מטפל מאמץ לעצמו בסופו של דבר את הגישה הטיפולית שמתוכה הוא עובד.',
      'אני עובדת בגישה פסיכודינמית (משלבת גם טכניקות קוגניטיביות התנהגותיות) כשעיקר העבודה נעשית על הלא מודע והעולם הפנימי של האדם.',
    ],
  },
  {
    title: 'הדרכה לאנשי טיפול',
    icon: 'teal',
    paras: [
      'העבודה בקליניקה עם מטופלים מחייבת הדרכה וליווי צמודים. התדירות נקבעת בהתאם לשלב ולצרכיו של המודרך.',
      'למודרך תינתן ההזדמנות להתבונן ולהביא באופן דיסקרטי ופתוח את הקשיים, ההתלבטויות, ההתמודדויות והאתגרים השונים הניצבים בפניו כמטפל ולהעמיק את ההבנות הטיפוליות שלו.',
      'זהו מרחב להתבוננות משותפת שבו "מחשבות מחפשות חושב" (ביון) מעין חוות דעת שנייה שתאפשר הסתכלות והפריה מנקודות מבט נוספות.',
    ],
  },
];
---

<Layout
  title="אסנת סוקר | פסיכותרפיסטית | מודיעין"
  description="טיפול נפשי פסיכותרפויטי בגישה פסיכודינמית. קליניקה במודיעין. אסנת סוקר, פסיכותרפיסטית."
>
  <!-- ============ 1 · HERO ============ -->
  <section id="home" class="hero">
    <div class="container hero__inner">
      <div class="hero__text animate-on-load">
        <span class="hero__mark" aria-hidden="true">”</span>
        <div class="hero__poem">
          {poem.map((line) => <p>{line}</p>)}
        </div>
        <p class="hero__attr">ריינה מריה רילקה, "מכתבים אל משורר צעיר"</p>
        <a class="btn hero__cta" href={`tel:${PHONE}`}>התקשרו, ראשית שיחה חינם</a>
      </div>

      <div class="hero__photo animate-on-load">
        <img src="/images/osnat-about.jpg" alt="אסנת סוקר, פסיכותרפיסטית" width="760" height="730" />
      </div>
    </div>
  </section>

  <!-- ============ 2 · WHY THERAPY (dark) ============ -->
  <Section id="why-therapy" bg="charcoal">
    <h2 class="why__title">מדוע אדם פונה לטיפול ?</h2>
    <div class="why__grid">
      <div class="why__body" data-animate>
        {whyParas.map((p) => <p class={p.bold ? 'is-bold' : ''}>{p.text}</p>)}
      </div>
      <div class="why__quote" data-animate>
        <blockquote class="quote-lime">{whyQuote}</blockquote>
        <p class="why__quote-sub">{whyQuoteSub}</p>
        <p class="why__quote-attr">{whyQuoteAttr}</p>
      </div>
    </div>
  </Section>
  <div class="stripe" aria-hidden="true"></div>

  <!-- ============ 3 · ABOUT ME (נעים מאוד) ============ -->
  <Section id="about" bg="white">
    <h2 class="eyebrow">נעים מאוד</h2>
    <div class="about__body" data-animate>
      {aboutParas.map((p) => <p>{p}</p>)}
    </div>
    <div class="center-cta" data-animate>
      <a class="btn" href="#contact">קבעו פגישת היכרות</a>
    </div>
  </Section>

  <!-- ============ 4 · ABOUT THERAPY (על הטיפול) ============ -->
  <Section id="psychotherapy" bg="white">
    <h2 class="eyebrow">על הטיפול</h2>
    <blockquote class="quote-teal therapy__head" data-animate>{therapyHeadQuote}</blockquote>
    <div class="therapy__body" data-animate>
      {therapyBlocks.map((b) => (
        b.bold ? <p class="therapy__sub">{b.text}</p> : <p>{b.text}</p>
      ))}
    </div>
    <ul class="keywords" data-animate aria-label="תחומי טיפול">
      {therapyKeywords.map((k) => <li>{k}</li>)}
    </ul>
  </Section>

  <!-- ============ 5 · SERVICES GRID ============ -->
  <Section id="services" bg="gray">
    <div class="services__grid">
      {services.map((s) => (
        <article class="service-card" data-animate>
          <div class="service-card__icon" set:html={iconSvg(s.icon)} />
          <div class="service-card__bar"><h3>{s.title}</h3></div>
          <div class="service-card__body">
            {s.paras.map((p) => <p>{p}</p>)}
          </div>
        </article>
      ))}

      <!-- Third column: contact details -->
      <article class="service-card service-card--contact" data-animate>
        <div class="service-card__icon" set:html={iconSvg('magenta')} />
        <div class="service-card__bar"><h3>יצירת קשר</h3></div>
        <div class="service-card__body service-card__contact">
          <p><strong class="c-magenta">כתובת הקליניקה:</strong><br />יער ירושלים 15/4, מודיעין</p>
          <p><strong>טלפון:</strong><br /><a href={`tel:${PHONE}`}>{PHONE}</a></p>
          <p><strong>אימייל:</strong><br /><a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
        </div>
      </article>
    </div>
  </Section>

  <!-- ============ 6 · CONTACT ============ -->
  <Section id="contact" bg="white">
    <div class="logo-divider" aria-hidden="true">
      <img src="/images/logo-text.png" alt="" width="120" height="50" />
    </div>
    <h2 class="eyebrow">יצירת קשר</h2>
    <div class="contact__grid">
      <div class="contact__details" data-animate>
        <h3 class="c-magenta">כתובת הקליניקה:</h3>
        <p>יער ירושלים 15/4, מודיעין</p>
        <p class="contact__en">Yaar Yerushalaim 15/4,<br />Modi'in-Maccabim-Re'ut</p>

        <h3 class="contact__lbl">טלפון:</h3>
        <p><a href={`tel:${PHONE}`}>{PHONE}</a></p>

        <h3 class="contact__lbl">אימייל:</h3>
        <p><a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
      </div>

      <div class="contact__form" data-animate>
        <ContactForm />
      </div>
    </div>
  </Section>

  <!-- Full-width Google Maps embed -->
  <div class="map-wrap" aria-label="מיקום הקליניקה">
    <iframe
      title="מיקום הקליניקה של אסנת סוקר במודיעין"
      src="https://maps.google.com/maps?q=%D7%99%D7%A2%D7%A8%20%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D%2015%2C%20%D7%9E%D7%95%D7%93%D7%99%D7%A2%D7%99%D7%9F&t=m&z=14&output=embed&iwloc=near"
      width="100%"
      height="320"
      style="border:0; display:block;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </div>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero {
    background-color: var(--color-bg-beige);
    background-image:
      linear-gradient(to bottom, rgba(241, 236, 225, 0.55), rgba(241, 236, 225, 0.9)),
      url('/images/osnat-home-bg.jpg');
    background-size: cover;
    background-position: center;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    min-height: 56vh;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero__text { position: relative; }
  .hero__mark {
    position: absolute;
    inset-inline-start: -0.5rem;
    top: -2.5rem;
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: var(--color-magenta);
    opacity: 0.85;
  }
  .hero__poem p {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.15rem, 2.4vw, 1.55rem);
    line-height: 1.7;
    color: var(--color-text);
  }
  .hero__attr {
    margin-top: 1.1rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .hero__cta { margin-top: 1.75rem; }
  .hero__photo { display: flex; justify-content: center; }
  .hero__photo img {
    width: clamp(220px, 30vw, 360px);
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
    border: 8px solid var(--color-magenta);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  /* ---------- WHY THERAPY ---------- */
  .why__title {
    text-align: center;
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    font-weight: 600;
    margin-bottom: 2.75rem;
  }
  .why__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .why__body p {
    color: #f1f1f1;
    font-size: 1rem;
    line-height: 1.95;
  }
  .why__body p.is-bold { font-weight: 700; color: #fff; }
  .why__quote { text-align: center; padding-top: 0.5rem; }
  .why__quote-sub { margin-top: 1.5rem; color: #e7e7e7; font-size: 1rem; }
